{
  "name": "Exploiticon",
  "version": "0.1.0",
  "permissions": {
    "network": {
      "whitelist": {
        "required": [
          "https://api.coinset.org"
        ],
        "optional": [
          "https://www.coinset.org",
          "wss://api.coinset.org"
        ]
      }
    },
    "capabilities": {
      "required": [],
      "optional": [
        "app.get_info",
        "app.get_capabilities",
        "app.request_capability_grant",
        "app.request_network_whitelist_grant",
        "persistent_storage",
        "wallet.send_xch"
      ]
    }
  }
}